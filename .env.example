# Copy to .env.local for local development
# On Vercel: set these in Project → Settings → Environment Variables

# Public site URL (no trailing slash)
# Local:  http://localhost:3000
# Vercel: https://your-project.vercel.app  (or your custom domain)
NEXTAUTH_URL=http://localhost:3000

# Generate a strong secret, e.g.:
#   openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-string

# Optional: force in-memory DB (auto-enabled on Vercel)
# USE_MEMORY_DB=1

# Optional but recommended on Vercel so public /p/[slug] cards persist:
# Free Redis: https://console.upstash.com → Create database → REST API
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXxxxx

# ─── Ziina payment gateway (AED) — see ZIINA_SETUP.md ───
# Without ZIINA_API_TOKEN the app stays in simulated payment mode.
# Bearer token from https://dashboard.ziina.com → Developers → API keys
# ZIINA_API_TOKEN=
# Shared secret for webhook signature verification (openssl rand -hex 32),
# registered with Ziina → Developers → Webhooks
# ZIINA_WEBHOOK_SECRET=
# Test mode is ON unless explicitly set to false (real charges)
# ZIINA_TEST_MODE=true
# USD → AED conversion rate for plan/card prices
# ZIINA_USD_TO_AED=3.6725
